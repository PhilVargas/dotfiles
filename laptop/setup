#!/usr/bin/env bash
#
# Bootstrap a fresh macOS machine from these dotfiles.
#
#   curl -fsSL https://raw.githubusercontent.com/PhilVargas/dotfiles/main/laptop/setup | bash
#
# Safe to re-run: every step is idempotent.

set -euo pipefail

DOTFILES="${DOTFILES:-$HOME/dotfiles}"
REPO_URL="https://github.com/PhilVargas/dotfiles.git"

log()  { printf "\n\033[1;34m==>\033[0m %s\n" "$1"; }
info() { printf "    %s\n" "$1"; }

#-------------------------------------------------------------
# Xcode command line tools (provides git, clang, make, ...)
#-------------------------------------------------------------
log "Checking for Xcode Command Line Tools"
if xcode-select -p >/dev/null 2>&1; then
  info "Already installed."
else
  info "Installing (expect a GUI popup)..."
  xcode-select --install
  info "Press any key once the installation has completed."
  read -r -n1 -s </dev/tty
fi

#-------------------------------------------------------------
# Homebrew
#-------------------------------------------------------------
log "Checking for Homebrew"
if command -v brew >/dev/null 2>&1; then
  info "Already installed. Updating..."
  brew update
else
  info "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
# Load brew into this shell (Apple Silicon path).
eval "$(/opt/homebrew/bin/brew shellenv)"

#-------------------------------------------------------------
# Dotfiles
#-------------------------------------------------------------
log "Fetching dotfiles"
if [[ -d "$DOTFILES" ]]; then
  info "Already present at $DOTFILES."
else
  git clone "$REPO_URL" "$DOTFILES"
fi

#-------------------------------------------------------------
# Homebrew packages
#-------------------------------------------------------------
log "Installing Homebrew packages from Brewfile"
brew bundle --file="$DOTFILES/Brewfile"

#-------------------------------------------------------------
# Symlinks: repo file -> location where the program expects it
#-------------------------------------------------------------
log "Linking dotfiles into place"

# Secret files are gitignored; create an empty one if missing before linking.
[[ -f "$DOTFILES/home/zshrc.secret" ]] || touch "$DOTFILES/home/zshrc.secret"
[[ -f "$DOTFILES/home/gitconfig.secret" ]] || touch "$DOTFILES/home/gitconfig.secret"

# link <repo-path> <home-path>: symlink $DOTFILES/<repo-path> -> $HOME/<home-path>
link() {
  local src="$DOTFILES/$1" dest="$HOME/$2"
  mkdir -p "$(dirname "$dest")"
  rm -rf "$dest"
  ln -s "$src" "$dest"
  info "~/$2 -> $1"
}

# dot <name>: shorthand for the common case, home/<name> -> ~/.<name>
dot() { link "home/$1" ".$1"; }

dot "zshrc"
dot "zshrc.secret"
dot "gitconfig"
dot "gitconfig.secret"
dot "gitignore_global"
dot "inputrc"
dot "rspec"
dot "ideavimrc"
dot "tmux.conf"
dot "vimrc"
dot "vimrc.bundles"
dot "vim"
dot "tmux"
dot "config/mise/config.toml"

# Files that don't follow the home/<name> -> ~/.<name> convention.
link "editor/settings.json" "Library/Application Support/Code/User/settings.json"
link "editor/settings.json" "Library/Application Support/Cursor/User/settings.json"
link "agents/CLAUDE.md"      ".claude/CLAUDE.md"

#-------------------------------------------------------------
# Language runtimes via mise (Ruby & Node)
#-------------------------------------------------------------
# Versions are declared in home/config/mise/config.toml (linked above).
log "Installing language runtimes with mise"
eval "$(mise activate bash)"
mise install
info "Enabling corepack (yarn / pnpm)"
mise exec -- corepack enable

log "Installing global gems"
mise exec -- gem install bundler rubocop

#-------------------------------------------------------------
# Vim plugins (vim-plug)
#-------------------------------------------------------------
log "Setting up vim-plug"
plug="$HOME/.vim/autoload/plug.vim"
if [[ -f "$plug" ]]; then
  info "vim-plug already installed."
else
  curl -fsSLo "$plug" --create-dirs \
    https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
fi
info "Installing plugins"
vim +PlugInstall +PlugClean! +qall

#-------------------------------------------------------------
# Editor theme extensions for VSCode + Cursor (best-effort; needs the CLI)
#-------------------------------------------------------------
for cli in code cursor; do
  command -v "$cli" >/dev/null 2>&1 || continue
  log "Installing $cli theme extensions"
  for ext in catppuccin.catppuccin-vsc enkia.tokyo-night; do
    "$cli" --install-extension "$ext" >/dev/null 2>&1 && info "$ext" || true
  done
done

#-------------------------------------------------------------
# Default shell
#-------------------------------------------------------------
log "Setting zsh as the default shell"
zsh_path="$(command -v zsh)"
if [[ "$SHELL" == "$zsh_path" ]]; then
  info "Already using zsh."
else
  chsh -s "$zsh_path"
fi

log "Setup complete. Open a new terminal to load your shell."
